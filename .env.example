# Resend API (server-side only — set in Vercel/Cloud Run Environment Variables)
RESEND_API_KEY=your_resend_api_key_here

# Email recipient (server-side only)
EMAIL_RECIPIENT=your-email@example.com

# Google Analytics 4 (client-side)
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# GCP Deployment (used by scripts/deploy.sh and scripts/provision-gcp.sh)
GCP_PROJECT_ID=prime-collective-website
GCP_REGION=asia-southeast1
GCP_SERVICE_NAME=prime-collective-landing
